{
  "mcpServers": {
    "workspace": {
      "owner": "security-engineering",
      "riskOwner": "ai-platform-owner",
      "command": "node",
      "args": ["server.js"],
      "allowedTools": ["read_file", "search_docs", "write_file", "run_shell"]
    },
    "tickets": {
      "owner": "it-operations",
      "riskOwner": "service-desk-owner",
      "url": "https://mcp.example.com/sse",
      "headers": {
        "Authorization": "Bearer ${MCP_TICKET_SEARCH_TOKEN}"
      },
      "allowedTools": ["search_tickets", "update_ticket"]
    },
    "deploy": {
      "owner": "platform-engineering",
      "riskOwner": "change-manager",
      "command": "node",
      "args": ["deploy-server.js"],
      "alwaysAllow": ["publish_release"]
    }
  }
}


{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/"],
      "env": {
        "GITHUB_TOKEN": "replace-me"
      }
    },
    "shell": {
      "command": "bash",
      "args": ["-lc", "python -c 'print(1)'"]
    },
    "remote-tools": {
      "url": "http://mcp.example.test/sse",
      "verify_ssl": false,
      "alwaysAllow": ["*"]
    },
    "docker-tools": {
      "command": "docker",
      "args": [
        "run",
        "--privileged",
        "--network=host",
        "-v",
        "/:/host",
        "-v",
        "/var/run/docker.sock:/var/run/docker.sock",
        "example/mcp:latest"
      ]
    }
  }
}

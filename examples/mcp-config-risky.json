{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/"],
      "env": {
        "GITHUB_TOKEN": "replace-me"
      }
    },
    "shell": {
      "command": "bash",
      "args": ["-lc", "python -c 'print(1)'"]
    },
    "remote-tools": {
      "url": "http://mcp.example.test/sse",
      "verify_ssl": false,
      "alwaysAllow": ["*"]
    },
    "docker-tools": {
      "command": "docker",
      "args": [
        "run",
        "--privileged",
        "--network=host",
        "-v",
        "/:/host",
        "-v",
        "/var/run/docker.sock:/var/run/docker.sock",
        "example/mcp:latest"
      ]
    },
    "browser-tools": {
      "command": "node",
      "args": [
        "browser-server.js",
        "--user-data-dir",
        "C:\\Users\\alice\\AppData\\Local\\Google\\Chrome\\User Data",
        "--cookie-file=./cookies.json"
      ]
    },
    "web-fetcher": {
      "command": "node",
      "args": [
        "fetch-server.js",
        "--allowed-host",
        "169.254.169.254"
      ],
      "egressAllowlist": "*"
    },
    "helpdesk-actions": {
      "command": "node",
      "args": ["action-server.js"],
      "alwaysAllow": ["search_docs", "create_ticket", "send_email", "merge_pull_request"]
    }
  }
}
